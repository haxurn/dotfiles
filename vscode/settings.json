{
  // ==================== Theme ====================
  // Uncomment and adjust for your preferred theme
  // "workbench.colorTheme": "Dark Modern",
  // "workbench.iconTheme": null,

  // ==================== Editor Font & Experience ====================
  "editor.fontFamily": "JetBrains Mono, 'Fira Code', Menlo, Monaco, monospace",
  "editor.fontSize": 15,
  "editor.fontLigatures": true,
  "editor.lineHeight": 1.65,
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "selection",
  "editor.smoothScrolling": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorBlinking": "smooth",
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.inlineSuggest.enabled": true,

  // ==================== Terminal Settings ====================
  // For Windows: powershell / pwsh / cmd
  // For macOS: /bin/zsh / /bin/bash
  // For Linux: /usr/bin/zsh / /usr/bin/bash
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.fontFamily": "'FiraCode Nerd Font', JetBrains Mono, monospace",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.lineHeight": 1.3,
  "terminal.integrated.scrollback": 15000,
  "terminal.integrated.cursorBlinkingStyle": "smooth",

  // ==================== Quality of Life ====================
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 800,
  "explorer.compactFolders": false,
  "workbench.tree.indent": 18,
  "workbench.startupEditor": "welcomePage",
  "workbench.enablePreview": false,

  // ==================== TypeScript / JavaScript ====================
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.suggest.autoImports": true,
  "javascript.suggest.autoImports": true,

  // ==================== Git ====================
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "always",

  // ==================== General UI ====================
  "window.zoomLevel": 0,
  "security.workspace.trust.enabled": true,
  "telemetry.telemetryLevel": "off",

  // ==================== Remote / SSH (if used) ====================
  "remote.SSH.showLoginTerminal": true
}
